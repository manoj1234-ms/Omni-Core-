# --- Omni-Core AGI Hive .gitignore ---

# Environment & Keys
.env
.DS_Store
*.env
auth_key.txt

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
pip-log.txt
pip-delete-this-directory.txt

# Local Memories & Research Logs
# (We keep these local to each machine, Sync happens via Cloud)
global_memories.json
omni_memories.json
*_graph.json
real_world_research.txt
test_results.txt
v8_training_log.txt
*.log

# Deployment & Temporary
/tmp/
.gemini/
/artifacts/ 
dashboard_pass.txt
# (Don't git ignore Procfile or requirements.txt!)

# Developer Tools
# (Keep for now as part of the repo, but exclude generated content)
__pycache__/
*.pyc

# Editor
.vscode/
.idea/
